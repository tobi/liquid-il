<div class="template-search">
  <div class="container">
    <h1 class="page-title">Search Results</h1>

    <div class="search-form">
      <form action="/search" method="get" role="search">
        <div class="search-form__field">
          <input type="search" name="q" class="search-form__input" value="{{ search.terms | escape }}" placeholder="Search our store">
          <button type="submit" class="search-form__button">Search</button>
        </div>
      </form>
    </div>

    {% if search.performed %}
      <div class="search-results">
        <p class="search-results__count">
          {% if search.results_count == 0 %}
            No results found for "{{ search.terms | escape }}".
          {% else %}
            {{ search.results_count }} result{% if search.results_count != 1 %}s{% endif %} for "{{ search.terms | escape }}".
          {% endif %}
        </p>

        {% if search.results_count > 0 %}
          {% assign _results = search.results %}
          {% paginate _results by 12 %}
            <div class="search-results__items product-grid">
              {% for item in _results %}
                {% if item.object_type == 'product' %}
                  {% assign product = item %}
                  {% include 'product-card' %}
                {% else %}
                  <div class="search-item">
                    <h3 class="search-item__title">
                      <a href="{{ item.url }}">{{ item.title }}</a>
                    </h3>
                    <div class="search-item__type">{{ item.object_type | capitalize }}</div>
                    <div class="search-item__excerpt">
                      {{ item.content | strip_html | truncatewords: 50 }}
                    </div>
                  </div>
                {% endif %}
              {% endfor %}
            </div>

            {% if paginate.pages > 1 %}
              <div class="pagination">
                {{ paginate | default_pagination }}
              </div>
            {% endif %}
          {% endpaginate %}
        {% endif %}
      </div>
    {% endif %}
  </div>
</div>
