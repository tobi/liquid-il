<div class="template-cart">
  <div class="container">
    <h1 class="page-title">Your Cart</h1>

    {% if cart.item_count > 0 %}
      <form action="/cart" method="post" novalidate class="cart-form">
        <div class="cart-table">
          <div class="cart-header">
            <div class="cart-header__col cart-header__col--product">Product</div>
            <div class="cart-header__col cart-header__col--price">Price</div>
            <div class="cart-header__col cart-header__col--quantity">Quantity</div>
            <div class="cart-header__col cart-header__col--total">Total</div>
          </div>

          <div class="cart-items">
            {% for item in cart.items %}
              <div class="cart-item" data-cart-item-key="{{ item.key }}">
                <div class="cart-item__col cart-item__col--product">
                  <div class="cart-item__image">
                    <a href="{{ item.url }}">
                      <img src="{{ item.image | product_img_url: 'small' }}" alt="{{ item.title | escape }}">
                    </a>
                  </div>
                  <div class="cart-item__details">
                    <h3 class="cart-item__title">
                      <a href="{{ item.url }}">{{ item.product.title }}</a>
                    </h3>
                    <div class="cart-item__variant">
                      {{ item.variant.title }}
                    </div>
                    <div class="cart-item__remove">
                      <a href="/cart/change?line={{ forloop.index }}&quantity=0" class="cart-item__remove-button">Remove</a>
                    </div>
                  </div>
                </div>

                <div class="cart-item__col cart-item__col--price">
                  {{ item.price | money }}
                </div>

                <div class="cart-item__col cart-item__col--quantity">
                  <div class="quantity-input">
                    <button type="button" class="quantity-input__button quantity-input__button--minus">-</button>
                    <input type="number" name="updates[]" id="updates_{{ item.key }}" class="quantity-input__field" value="{{ item.quantity }}" min="0" pattern="[0-9]*">
                    <button type="button" class="quantity-input__button quantity-input__button--plus">+</button>
                  </div>
                </div>

                <div class="cart-item__col cart-item__col--total">
                  {{ item.line_price | money }}
                </div>
              </div>
            {% endfor %}
          </div>
        </div>

        <div class="cart-footer">
          <div class="cart-footer__actions">
            <div class="cart-footer__update">
              <button type="submit" name="update" class="button button--secondary">Update Cart</button>
            </div>
            <div class="cart-footer__continue">
              <a href="/collections/all" class="button button--text">Continue Shopping</a>
            </div>
          </div>

          <div class="cart-footer__summary">
            <div class="cart-summary">
              <div class="cart-summary__row">
                <span class="cart-summary__label">Subtotal</span>
                <span class="cart-summary__value">{{ cart.total_price | money }}</span>
              </div>
              <div class="cart-summary__row">
                <span class="cart-summary__label">Shipping</span>
                <span class="cart-summary__value">Calculated at checkout</span>
              </div>
              <div class="cart-summary__row cart-summary__row--total">
                <span class="cart-summary__label">Total</span>
                <span class="cart-summary__value">{{ cart.total_price | money }}</span>
              </div>
              <div class="cart-summary__checkout">
                <button type="submit" name="checkout" class="button button--primary button--full">Checkout</button>
              </div>
            </div>
          </div>
        </div>
      </form>
    {% else %}
      <div class="cart-empty">
        <p>Your cart is currently empty.</p>
        <div class="cart-empty__button">
          <a href="/collections/all" class="button button--primary">Continue Shopping</a>
        </div>
      </div>
    {% endif %}
  </div>
</div>
